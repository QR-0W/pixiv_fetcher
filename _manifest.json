{
  "manifest_version": 1,
  "name": "Pixiv OAuth 图片插件",
  "version": "2.0.0",
  "description": "基于 pixivpy 官方库实现的 Pixiv 图片获取插件。支持标签AND/OR组合搜索、关键词搜索、用户搜索、作品ID搜索、日期搜索、长宽比筛选、AI作品排除、R18内容控制等功能。",
  "author": {
    "name": "Kilo Code",
    "url": "https://github.com/MaiM-with-u"
  },
  "license": "MIT",
  "homepage_url": "https://github.com/MaiM-with-u/maibot",
  "repository_url": "https://github.com/MaiM-with-u/maibot",
  "host_application": {
    "min_version": "0.11.0"
  },
  "keywords": [
    "pixiv",
    "oauth",
    "illustration",
    "image",
    "图片",
    "搜索",
    "pixivpy"
  ],
  "categories": [
    "Entertainment & Interaction",
    "External Integration"
  ],
  "default_locale": "zh-CN",
  "plugin_info": {
    "is_built_in": false,
    "plugin_type": "general",
    "components": [
      {
        "type": "command",
        "name": "pixiv",
        "description": "通过 Pixiv OAuth 获取图片"
      }
    ]
  },
  "permissions": [
    "send.image",
    "send.text",
    "send.forward",
    "network.http"
  ],
  "changelog": {
    "2.0.0": {
      "date": "2026-03-31",
      "changes": [
        "基于 pixivpy 官方库重写，提升稳定性",
        "新增 random:N 随机获取多个帖子功能",
        "新增 tag:XXX|YYY OR搜索支持",
        "新增 user:用户名 按用户名搜索",
        "新增 id:作品ID 按作品ID搜索",
        "新增 date:YYYY-MM-DD 按日期搜索",
        "优化参数解析，支持所有参数自由组合",
        "内置代理支持，自动处理Pixiv访问限制",
        "自动Token刷新机制"
      ]
    }
  },
  "id": "Kilo Code.maibot"
}